+void capture_depth()
+{
+	if (!cl_ssao || cl_ssao->value == 0.0f) return;
+	GLint vp[4];
+	glGetIntegerv(GL_VIEWPORT, vp);
+	int w = vp[2], h = vp[3];
+	if (w <= 0 || h <= 0) return;
+	if (g_DepthW != w || g_DepthH != h) {
+		if (g_DepthData) delete[] g_DepthData;
+		g_DepthData = new GLfloat[w * h];
+		g_DepthW = w; g_DepthH = h;
+	}
+	glReadPixels(vp[0], vp[1], w, h, GL_DEPTH_COMPONENT, GL_FLOAT, g_DepthData);
+	if (!g_TexDepth) return;
+	glBindTexture(GL_TEXTURE_2D, g_TexDepth);
+	glTexSubImage2D(GL_TEXTURE_2D, 0, 0, 0, w, h, GL_DEPTH_COMPONENT, GL_FLOAT, g_DepthData);
+}
 
